datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Workspace {
  id             Int       @id @default(autoincrement())
  wid            Int       @unique
  name           String
  slug           String?   @unique
  formCategories Json      @default("[]")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  profiles       Profile[]
}

model Profile {
  id                     String    @id @default(uuid())
  email                  String    @unique
  password               String
  name                   String
  phone                  String    @default("")
  bio                    String    @default("")
  accent                 String    @default("emerald")
  wid                    Int       @default(1)
  hasCompletedOnboarding Boolean   @default(false)
  acceptedPolicies       Boolean   @default(false)
  policiesAcceptedAt     DateTime?
  pricingPlan            String    @default("Free Trial") // "Free", "Free Trial", or "Pro"
  trialEndsAt            DateTime? // When the 14-day trial ends
  // Extended profile fields
  dob                    String    @default("")
  bloodGroup             String    @default("")
  officeLocation         String    @default("")
  pincode                String    @default("")
  state                  String    @default("")
  city                   String    @default("")
  emergencyName          String    @default("")
  emergencyPhone         String    @default("")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  workspace              Workspace @relation(fields: [wid], references: [wid])
  forms                  Form[]
}

model Form {
  id           String       @id @default(uuid())
  title        String
  description  String       @default("")
  category     String       @default("General")
  isPublished  Boolean      @default(false)
  slug         String       @unique // Public URL slug
  fields       Json         @default("[]") // Array of fields
  steps        Json         @default("[]") // Multi-step definition
  landingPage  Json         @default("{}") // Landing page config
  settings     Json         @default("{}") // Custom branding & settings
  views        Int          @default(0)
  profileId    String
  profile      Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  submissions  Submission[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Submission {
  id            String   @id @default(uuid())
  formId        String
  form          Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  customId      String   @unique // e.g. ANSH-12345
  answers       Json     // Key-value response data
  status        String   @default("Submitted") // Submitted, Under Review, Approved, Rejected
  statusComment String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SupportTicket {
  id          String          @id @default(uuid())
  ticketId    String          @unique // e.g. TKT-00123
  email       String          // Requester email
  name        String          // Requester name
  subject     String
  description String          @default("")
  category    String          @default("General")     // General, Billing, Technical, Feature Request, Bug
  priority    String          @default("Medium")      // Low, Medium, High, Critical
  status      String          @default("Open")        // Open, In Progress, Resolved, Closed
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  replies     SupportReply[]
}

model SupportReply {
  id          String        @id @default(uuid())
  ticketDbId  String
  ticket      SupportTicket @relation(fields: [ticketDbId], references: [id], onDelete: Cascade)
  message     String
  isAdmin     Boolean       @default(false)
  authorEmail String        @default("")
  authorName  String        @default("")
  createdAt   DateTime      @default(now())
}
