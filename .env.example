# Supabase Authentication & Client configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Prisma DB Connections
DATABASE_URL="postgresql://user:pass@host:6543/postgres?pgbouncer=true&schema=forms"
DIRECT_URL="postgresql://user:pass@host:5432/postgres?schema=forms"

# Cloudflare R2 / S3 Storage configurations
S3_REGION=ap-south-1
S3_ENDPOINT=https://your-cloudflare-r2-endpoint.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-r2-access-key-id
S3_SECRET_ACCESS_KEY=your-r2-secret-access-key
S3_BUCKET_NAME=ansh-forms

# Gemini API configuration for AI form generator
GEMINI_API_KEY=your-gemini-api-key

# Admin panel (forms.anshapps.com/adminpanel)
ADMIN_EMAIL=forms@anshapps.com
ADMIN_PASSWORD=Rahul@123
ADMIN_PASSCODE=Khushi@Simran
ADMIN_PIN=30042026
ADMIN_SESSION_SECRET=change-this-to-a-long-random-string

# Razorpay billing (Pro plan checkout)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Optional: expose key id to client if not using RAZORPAY_KEY_ID above
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id

# SEO & Domain Configuration
NEXT_PUBLIC_SITE_URL=https://forms.anshapps.com
GOOGLE_SITE_VERIFICATION=your-code-from-search-console
